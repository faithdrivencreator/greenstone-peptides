NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=your_sanity_write_token_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_SITE_URL=https://greenstonewellness.store

# --- Resend (transactional + ebook lead capture) ---
# API key issued in the Resend dashboard. Required.
RESEND_API_KEY=re_...
# Audience ID for the ebook subscriber list (create in Resend dashboard → Audiences).
# Optional — if unset, the route still sends the delivery email but skips the contact-add step.
RESEND_AUDIENCE_ID=
# Default from-address for the ebook delivery email. Override only if the verified domain changes.
RESEND_FROM_EMAIL=hello@greenstonewellness.store
